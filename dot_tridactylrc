" Custom command: switch to existing tab or open new one
" Uses startsWith for partial URL matching (handles trailing slashes, query params, etc.)
command tabopen_or_switch jsb -p browser.tabs.query({}).then(tabs => { const url = JS_ARG; const existingTab = tabs.find(t => t.url.startsWith(url) || url.startsWith(t.url)); if (existingTab) { browser.tabs.update(existingTab.id, { active: true }); browser.windows.update(existingTab.windowId, { focused: true }); } else { browser.tabs.create({ url }); } })

